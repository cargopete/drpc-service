# Deployer
PRIVATE_KEY=0x...

# Graph Protocol Controller (GraphDirectory) on Arbitrum Sepolia
GRAPH_CONTROLLER=0x...

# Address authorised to pause the service in an emergency
PAUSE_GUARDIAN=0x...

# RPC endpoints (see foundry.toml [rpc_endpoints])
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Arbiscan API key for contract verification
ARBISCAN_API_KEY=...

# Set after deployment
RPC_DATA_SERVICE_ADDRESS=0x...

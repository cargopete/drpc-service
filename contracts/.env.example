CAPABILITY_TIER=2

# ── Block explorer ────────────────────────────────────────────────────────────
ARBISCAN_API_KEY=

# ── RPC endpoints (foundry.toml) ──────────────────────────────────────────────
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
